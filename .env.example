# Copy to .env.local for local dev. In Netlify: Site settings → Environment variables.
# Create a project at https://supabase.com → Project Settings → API
#
# IMPORTANT: VITE_SUPABASE_ANON_KEY must be the "anon" / "public" key (safe for browsers).
# Never paste the "service_role" secret here — the client will get 401 errors and
# "Forbidden use of secret API key in browser".

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Required: Authentication → Providers → Email → Enable. Users sign up with email + password.
#
# Authentication → URL Configuration: set **Site URL** to the app users should return to
# (e.g. https://your-app.netlify.app or http://localhost:5173 for local dev). Sign-up and
# password-reset emails use that URL unless you override below.
#
# Optional: only if you need a specific redirect and have added it to **Redirect URLs**:
# VITE_AUTH_EMAIL_REDIRECT_URL=https://your-app.example.com/
# Do NOT set this to localhost unless http://localhost:5173/** is in Redirect URLs — otherwise
# sign-up returns 422 (Unprocessable Content).
# Then run the SQL in supabase/migrations/001_initial.sql in the SQL Editor.
# For the full schema, also run supabase/migrations/003_full_schema.sql.
# Run supabase/migrations/005_profile_on_auth_user.sql so every new auth user gets a
# profiles row automatically (fixes empty profiles when email confirmation defers the client session).
# If you see PGRST205 / "Could not find wc_predictions", run 006_wc_predictions_table.sql
# (003_full_schema assumes 001 already created that legacy table).

# API-Football — sign up at https://www.api-football.com/ (free tier: 100 req/day)
# Dashboard → My Account → copy your API key
VITE_API_FOOTBALL_KEY=your-api-football-key

# Optional: ISO 8601 datetime for the first tournament match kick-off (local app uses this
# to compute the submission deadline = 1 hour before). If unset, the earliest fixture from
# the API is used when available; otherwise a built-in fallback date applies.
# VITE_FIRST_MATCH_KICKOFF_ISO=2026-06-11T22:00:00.000Z

# Optional: percentage taken from the gross pot for organiser costs before prize payouts.
# Example: 10 means 10% costs, 90% payout pool.
VITE_COST_PERCENT=10

# ── Stripe (for £10 entry payments) ──────────────────────────────────────────
# 1. Create an account at https://stripe.com
# 2. Developers → API Keys → copy your publishable + secret keys
# 3. The STRIPE_SECRET_KEY goes in Supabase Edge Function secrets (not here)
#    Run: supabase secrets set STRIPE_SECRET_KEY=sk_live_xxx
#    Run: supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_xxx
# 4. Set up a webhook endpoint in Stripe Dashboard:
#    URL: https://your-project.supabase.co/functions/v1/stripe-webhook
#    Events: checkout.session.completed, checkout.session.expired, charge.refunded
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ── Resend (for email notifications) ─────────────────────────────────────────
# 1. Create an account at https://resend.com
# 2. API Keys → Create key → copy it
# 3. The RESEND_API_KEY goes in Supabase Edge Function secrets:
#    Run: supabase secrets set RESEND_API_KEY=re_xxx
#    Run: supabase secrets set FROM_EMAIL="WC Predictions <noreply@yourdomain.com>"
# 4. Add and verify your sending domain in Resend → Domains

# ── Edge Function secrets summary ────────────────────────────────────────────
# Run these in your terminal after installing the Supabase CLI:
#   supabase secrets set STRIPE_SECRET_KEY=sk_live_xxx
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_xxx
#   supabase secrets set RESEND_API_KEY=re_xxx
#   supabase secrets set FROM_EMAIL="WC Predictions <noreply@yourdomain.com>"
#   supabase secrets set APP_URL=https://your-app-url.com
